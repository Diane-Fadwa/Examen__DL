from pyspark.sql import SparkSession
import sys
import json

def main():
    data_json = sys.argv[1]
    rows = json.loads(data_json)

    spark = SparkSession.builder \
        .appName("Airflow_Iceberg_Insert") \
        .config("spark.sql.catalog.spark_catalog", "org.apache.iceberg.spark.SparkSessionCatalog") \
        .config("spark.sql.catalog.spark_catalog.type", "hive") \
        .enableHiveSupport() \
        .getOrCreate()

    df = spark.createDataFrame(rows)

    df = df.selectExpr(
        "cast(dag_id as string)",
        "cast(run_id as string)",
        "cast(execution_date as timestamp)",
        "cast(event_time as timestamp)",
        "cast(job_status as string)",
        "cast(failed_task as string)",
        "cast(duration as bigint)",
        "cast(source as string)"
    )

    df.writeTo("spark_catalog.awb_rec.icbrg_airflow_flux_status").append()

    spark.stop()

if __name__ == "__main__":
    main()




