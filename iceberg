from airflow import DAG
from airflow.operators.python import PythonOperator
from datetime import datetime
import requests
import json
import logging

from knox_livy_hook import KnoxLivyHook

AIRFLOW_API = "http://airflow/api/v1"
SCRIPT_PATH = "hdfs:///user/ton_user/insert_iceberg_airflow.py"


def collect_task_instances(**context):

    events = []

    dags = requests.get(f"{AIRFLOW_API}/dags").json().get("dags", [])

    for dag in dags:
        dag_id = dag["dag_id"]

        runs = requests.get(
            f"{AIRFLOW_API}/dags/{dag_id}/dagRuns"
        ).json().get("dag_runs", [])

        for run in runs:

            run_id = run["dag_run_id"]
            state = run["state"]

            if state not in ["success", "failed"]:
                continue

            tasks = requests.get(
                f"{AIRFLOW_API}/dags/{dag_id}/dagRuns/{run_id}/taskInstances"
            ).json().get("task_instances", [])

            for task in tasks:
                events.append({
                    "dag_id": dag_id,
                    "run_id": run_id,
                    "execution_date": run["execution_date"],
                    "event_time": datetime.utcnow().isoformat(),
                    "job_status": state.upper(),
                    "failed_task": task["task_id"] if state == "failed" else "",
                    "duration": int(task.get("duration") or 0),
                    "source": "BATCH"
                })

    logging.info(f"{len(events)} events collectés")
    return events


def send_to_livy(**context):

    events = context["ti"].xcom_pull(task_ids="collect")

    if not events:
        return

    hook = KnoxLivyHook(conn_id="knox_default")

    batch_id = hook.post_batch(
        file=SCRIPT_PATH,
        args=[json.dumps(events)],
        conf={
            "spark.sql.catalog.spark_catalog": "org.apache.iceberg.spark.SparkSessionCatalog",
            "spark.sql.catalog.spark_catalog.type": "hive"
        }
    )

    hook.poll_for_completion(batch_id)


with DAG(
    dag_id="iceberg_airflow_batch",
    start_date=datetime(2024, 1, 1),
    schedule_interval="@hourly",
    catchup=False,
) as dag:

    collect = PythonOperator(
        task_id="collect",
        python_callable=collect_task_instances
    )

    send = PythonOperator(
        task_id="send",
        python_callable=send_to_livy
    )

    collect >> send




def handle_failure(context):
    from knox_livy_hook import KnoxLivyHook
    import json
    from datetime import datetime

    ti = context["task_instance"]

    event = {
        "dag_id": context["dag"].dag_id,
        "run_id": context["run_id"],
        "execution_date": str(context["logical_date"]),
        "event_time": datetime.utcnow().isoformat(),
        "job_status": "TIMEDOUT",
        "failed_task": ti.task_id,
        "duration": int(ti.duration or 0),
        "source": "SENSOR"
    }

    hook = KnoxLivyHook(conn_id="knox_default")

    hook.post_batch(
        file="hdfs:///user/ton_user/insert_iceberg_airflow.py",
        args=[json.dumps([event])]
    )
