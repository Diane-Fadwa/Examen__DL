import requests
from airflow.exceptions import AirflowException

from awb_lib.providers.knox.hooks.knox_base_hook import KnoxBaseHook


class KnoxHttpHook(KnoxBaseHook):
    """
    Generic Hook for REST services via Knox (Livy, WebHDFS, Atlas, etc.).
    Inherits Auth/Session logic from KnoxBaseHook.
    """

    def __init__(
        self,
        service: str,
        conn_id: str = "knox_default",
        method: str = "GET",
        timeout: int = 60,
    ):
        """
        :param service: Service suffix (e.g. 'livy', 'webhdfs/v1')
        """
        super().__init__(conn_id=conn_id)
        self.service = service
        self.method = method.upper()
        self.timeout = timeout

    def run(
        self,
        endpoint: str = "",
        data: dict = None,
        headers: dict = None,
        extra_options: dict = None,
    ):
        """
        Executes the HTTP Request.
        """
        # 1. Reuse logic from Parent
        session = self.get_knox_session()
        base_url = self.get_base_url(self.service)

        # 2. Construct specific endpoint URL
        if endpoint and not endpoint.startswith("/"):
            endpoint = "/" + endpoint
        url = base_url + endpoint

        # 3. Handle Payload & Headers
        # For WebHDFS and similar REST APIs, query params should be in URL for all methods
        # Only POST/PUT/PATCH with JSON body should use json_data
        params = None
        json_data = None

        if data:
            if self.method in ("POST", "PUT", "PATCH"):
                # Check if data looks like query params (all string/int values) or JSON body
                # For WebHDFS, most PUT operations need query params, not JSON body
                if all(isinstance(v, (str, int, bool)) for v in data.values()):
                    params = data
                else:
                    json_data = data
            else:
                # GET, DELETE, etc. - always use query params
                params = data

        req_headers = session.headers.copy()
        if headers:
            req_headers.update(headers)

        self.log.info(f"Knox HTTP Request: {self.method} {url}")
        if params:
            self.log.info(f"Query params: {params}")
        if json_data:
            self.log.info(f"JSON body: {json_data}")

        try:
            response = session.request(
                method=self.method,
                url=url,
                params=params,
                json=json_data,
                headers=req_headers,
                timeout=self.timeout,
                **(extra_options or {}),
            )

            if response.status_code >= 400:
                self.log.error(f"Knox Error Body: {response.text[:500]}")
                response.raise_for_status()

            return response

        except requests.RequestException as e:
            raise AirflowException(f"Knox Connection Failed ({self.service}): {e}")
