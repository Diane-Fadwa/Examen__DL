import time
from typing import Any

from airflow.exceptions import AirflowException
from airflow.providers.apache.livy.hooks.livy import BatchState, LivyHook

from awb_lib.providers.knox.hooks.knox_http_hook import KnoxHttpHook


class KnoxLivyHook(LivyHook):
    """
    Custom Livy Hook that routes requests through Knox Gateway.
    Inherits all Livy logic from LivyHook but uses Knox for transport.
    """

    def __init__(self, conn_id: str = "knox_default", *args, **kwargs):
        """
        :param conn_id: Knox connection ID
        """
        super().__init__(livy_conn_id=conn_id, *args, **kwargs)
        self.knox_conn_id = conn_id
        self.service = "livy_for_spark3"

    def run_method(self, endpoint: str, method: str = "GET", data: dict = None):
        """
        Route API calls through Knox using KnoxHttpHook.

        :param endpoint: Livy API endpoint (e.g., '/batches', '/batches/1')
        :param method: HTTP method
        :param data: Request payload
        :return: Response JSON
        """
        knox_hook = KnoxHttpHook(
            service=self.service, conn_id=self.knox_conn_id, method=method, timeout=180
        )

        try:
            response = knox_hook.run(
                endpoint=endpoint,
                data=data,
                headers={
                    "Content-Type": "application/json",
                    "Accept": "application/json",
                },
            )

            self.log.info(
                f"Knox Livy Response [{response.status_code}]: {response.text[:500]}"
            )

            if response.status_code >= 400:
                self.log.error(f"Livy Error Response: {response.text}")
                raise AirflowException(
                    f"Livy request failed with status {response.status_code}: {response.text}"
                )

            return response.json()

        except Exception as e:
            self.log.error(f"Knox Livy API call failed: {str(e)}")
            raise

    def post_batch(self, *args, **kwargs) -> int:
        """
        Override parent's post_batch to route through Knox.
        Returns batch_id as integer (not dict).
        """
        # Build batch configuration from operator parameters
        batch_config = self._build_batch_from_config(*args, **kwargs)

        # Log the batch configuration for debugging
        self.log.info(f"Submitting Livy batch with config: {batch_config}")

        # Make POST request through Knox
        result = self.run_method(endpoint="/batches", method="POST", data=batch_config)

        batch_id = result.get("id")
        self.log.info(
            f"Batch submitted successfully. ID: {batch_id}, State: {result.get('state')}"
        )

        # Return just the ID (integer), not the full response
        return batch_id

    def _build_batch_from_config(self, *args, **kwargs) -> dict:
        """
        Build Livy batch configuration from operator parameters.
        Ensures all required fields are present.
        """
        batch_config = {}

        # Required fields
        if "file" in kwargs:
            batch_config["file"] = kwargs["file"]

        # Optional fields
        if "class_name" in kwargs and kwargs["class_name"]:
            batch_config["className"] = kwargs["class_name"]

        if "args" in kwargs and kwargs["args"]:
            batch_config["args"] = kwargs["args"]

        if "jars" in kwargs and kwargs["jars"]:
            batch_config["jars"] = kwargs["jars"]

        if "py_files" in kwargs and kwargs["py_files"]:
            batch_config["pyFiles"] = kwargs["py_files"]

        if "files" in kwargs and kwargs["files"]:
            batch_config["files"] = kwargs["files"]

        if "driver_memory" in kwargs:
            batch_config["driverMemory"] = kwargs["driver_memory"]

        if "driver_cores" in kwargs:
            batch_config["driverCores"] = kwargs["driver_cores"]

        if "executor_memory" in kwargs:
            batch_config["executorMemory"] = kwargs["executor_memory"]

        if "executor_cores" in kwargs:
            batch_config["executorCores"] = kwargs["executor_cores"]

        if "num_executors" in kwargs:
            batch_config["numExecutors"] = kwargs["num_executors"]

        if "archives" in kwargs and kwargs["archives"]:
            batch_config["archives"] = kwargs["archives"]

        if "queue" in kwargs and kwargs["queue"]:
            batch_config["queue"] = kwargs["queue"]

        if "name" in kwargs and kwargs["name"]:
            batch_config["name"] = kwargs["name"]

        if "conf" in kwargs and kwargs["conf"]:
            batch_config["conf"] = kwargs["conf"]

        if "proxy_user" in kwargs:
            batch_config["proxyUser"] = kwargs["proxy_user"]

        if "file" not in batch_config:
            raise AirflowException("'file' parameter is required for Livy batch")

        return batch_config

    def get_batch_state(self, session_id: int, *args, **kwargs) -> BatchState:
        """
        Get batch state through Knox.
        Returns BatchState object expected by parent class.
        """
        result = self.run_method(endpoint=f"/batches/{session_id}", method="GET")

        state = result.get("state", "unknown").upper()
        self.log.info(f"Batch {session_id} state: {state}")

        # Map Livy states to BatchState enum
        state_mapping = {
            "NOT_STARTED": BatchState.NOT_STARTED,
            "STARTING": BatchState.STARTING,
            "RUNNING": BatchState.RUNNING,
            "IDLE": BatchState.IDLE,
            "BUSY": BatchState.BUSY,
            "SHUTTING_DOWN": BatchState.SHUTTING_DOWN,
            "ERROR": BatchState.ERROR,
            "DEAD": BatchState.DEAD,
            "KILLED": BatchState.KILLED,
            "SUCCESS": BatchState.SUCCESS,
        }

        return state_mapping.get(state, BatchState.ERROR)

    def get_batch(self, session_id: int) -> dict:
        """
        Get batch details through Knox.
        Returns full batch information as dict.
        """
        return self.run_method(endpoint=f"/batches/{session_id}", method="GET")

    def delete_batch(self, session_id: int) -> Any:
        """
        Delete a batch through Knox.
        """
        result = self.run_method(endpoint=f"/batches/{session_id}", method="DELETE")
        self.log.info(f"Batch {session_id} deleted")
        return result

    def get_batch_logs(
        self, session_id: int, log_start_position: int = 0, log_batch_size: int = 100
    ) -> dict:
        """
        Get batch logs through Knox.
        """
        result = self.run_method(
            endpoint=f"/batches/{session_id}/log",
            method="GET",
            data={"from": log_start_position, "size": log_batch_size},
        )
        return result

    def dump_batch_logs(self, session_id: int) -> None:
        """
        Dump all logs for a batch job.
        """
        self.log.info(f"=" * 80)
        self.log.info(f"Fetching logs for batch {session_id}")
        self.log.info(f"=" * 80)

        log_start = 0
        log_batch_size = 100

        while True:
            log_response = self.get_batch_logs(session_id, log_start, log_batch_size)

            logs = log_response.get("log", [])
            if not logs:
                break

            for log_line in logs:
                self.log.info(log_line)

            # Check if we've fetched all logs
            total = log_response.get("total", 0)
            log_start += len(logs)

            if log_start >= total:
                break

        self.log.info(f"=" * 80)
        self.log.info(f"End of logs for batch {session_id}")
        self.log.info(f"=" * 80)

    def poll_for_completion(
        self,
        session_id: int,
        polling_interval: int = 30,
        max_polling_attempts: int = 120,
    ) -> BatchState:
        """
        Poll batch status until completion.

        :param session_id: Batch ID
        :param polling_interval: Seconds between polls
        :param max_polling_attempts: Maximum polling attempts
        :return: Final batch state
        """
        self.log.info(f"Starting to poll batch {session_id} for completion")

        attempts = 0
        while attempts < max_polling_attempts:
            attempts += 1

            state = self.get_batch_state(session_id)
            batch_info = self.get_batch(session_id)

            app_id = batch_info.get("appId")
            app_info = batch_info.get("appInfo", {})
            spark_ui = app_info.get("sparkUiUrl")

            self.log.info(
                f"Poll attempt {attempts}/{max_polling_attempts}: "
                f"Batch {session_id} state: {state.value}, "
                f"AppId: {app_id}, SparkUI: {spark_ui}"
            )

            # Check if job is in terminal state
            if state in (
                BatchState.SUCCESS,
                BatchState.ERROR,
                BatchState.DEAD,
                BatchState.KILLED,
            ):
                self.log.info(
                    f"Batch {session_id} reached terminal state: {state.value}"
                )

                # Dump logs
                self.dump_batch_logs(session_id)

                if state == BatchState.SUCCESS:
                    self.log.info(f"Batch {session_id} completed successfully!")
                    return state
                else:
                    self.log.error(
                        f"Batch {session_id} failed with state: {state.value}"
                    )
                    raise AirflowException(
                        f"Batch {session_id} failed with state: {state.value}"
                    )

            # Sleep before next poll
            time.sleep(polling_interval)

        # Max attempts reached
        self.log.error(
            f"Batch {session_id} did not complete within {max_polling_attempts} attempts"
        )
        self.dump_batch_logs(session_id)
        raise AirflowException(
            f"Batch {session_id} polling timed out after {max_polling_attempts} attempts"
        )
